
# Backend Environment Variables
PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skillify?retryWrites=true&w=majority
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars

# MongoDB Atlas free tier:
# 1. Create free account at cloud.mongodb.com
# 2. Create cluster → Connect → Drivers → Copy connection string
# 3. Replace username/password → whitelist 0.0.0.0/0 → Network Access

